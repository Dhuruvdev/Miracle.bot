# ─────────────────────────────────────────────────────────────────────────────
# OpenEmbedded Desktop — Environment Variables
# Copy this to .env and set APP_URL to your deployed site.
# ─────────────────────────────────────────────────────────────────────────────

# The live website the app window will load.
# Set this to your deployed Replit URL or custom domain.
APP_URL=https://discord.builders

# Your Discord application ID — used for Rich Presence.
# Must match the Client ID in your Discord Developer Portal app.
DISCORD_CLIENT_ID=your_client_id_here

# Set to 1 to run in dev mode (loads http://localhost:5000 instead of APP_URL)
# ELECTRON_DEV=1
